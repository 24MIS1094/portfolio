# Portfolio Contact Form Email Forwarder Credentials
# Copy this file to .env.local for local testing, or add these keys to your Vercel Dashboard settings.

# Option 1: Resend API (Highly Recommended)
# 1. Sign up for a free account at https://resend.com
# 2. Generate a free API Key and paste it below.
# Note: On a free Resend tier, you can send emails to yourself (ajayarjun727@gmail.com) instantly using 'onboarding@resend.dev'!
RESEND_API_KEY=re_your_api_key_here

# Option 2: Web3Forms API (Alternative Gateway)
# 1. Obtain a free access key at https://web3forms.com
# 2. Paste your access key below.
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key-here
